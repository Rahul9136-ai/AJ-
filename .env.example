# Pick a provider (default: gemini). Each needs its own free key.
# AGENT_PROVIDER=gemini

# Google Gemini — free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq — free key: https://console.groq.com/keys
# GROQ_API_KEY=

# Automatic failover: if the primary provider is rate-limited, AJ retries the same
# request on the next provider in this list. Only providers with a key (or Ollama,
# which is local) are used. Default order below.
# AGENT_FALLBACKS=groq,gemini,ollama

# Optional overrides:
# AGENT_MODEL=gemini-2.5-flash-lite   # model for the PRIMARY provider
# GROQ_MODEL=llama-3.3-70b-versatile  # per-provider model override (<NAME>_MODEL)
# AGENT_MAX_TOKENS=2048

# Dashboard password — set this to require a login on the Streamlit app.
# AJ_PASSWORD=choose-a-strong-password
