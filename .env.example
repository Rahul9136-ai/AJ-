# Pick a provider (default: gemini). Each needs its own free key.
# AGENT_PROVIDER=gemini

# Google Gemini — free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq — free key: https://console.groq.com/keys
# GROQ_API_KEY=

# Optional overrides:
# AGENT_MODEL=gemini-2.0-flash      # e.g. gemini-2.5-flash, or a Groq/Ollama model
# AGENT_MAX_TOKENS=2048

# Dashboard password — set this to require a login on the Streamlit app.
# AJ_PASSWORD=choose-a-strong-password
